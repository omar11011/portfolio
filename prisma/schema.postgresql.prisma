generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id          String   @id @default(cuid())
  name        String   @default("Tu Nombre")
  title       String   @default("Desarrollador Full Stack")
  bio         String   @default("Apasionado por la tecnología y la innovación. Creo soluciones digitales que impactan positivamente.")
  avatarUrl   String   @default("")
  email       String   @default("")
  phone       String   @default("")
  location    String   @default("")
  github      String   @default("")
  linkedin    String   @default("")
  twitter     String   @default("")
  website     String   @default("")
  updatedAt   DateTime @updatedAt
}

model Education {
  id              String   @id @default(cuid())
  type            String   @default("course")
  institution     String   @default("")
  title           String   @default("")
  startDate       String   @default("")
  endDate         String   @default("")
  description     String   @default("")
  certificateUrl  String   @default("")
  certificateName String   @default("")
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Experience {
  id          String   @id @default(cuid())
  company     String   @default("")
  role        String   @default("")
  startDate   String   @default("")
  endDate     String   @default("")
  current     Boolean  @default(false)
  description String   @default("")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String   @default("")
  description String   @default("")
  imageUrl    String   @default("")
  techStack   String   @default("")
  liveUrl     String   @default("")
  repoUrl     String   @default("")
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogPost {
  id            String   @id @default(cuid())
  title         String   @default("")
  content       String   @default("")
  excerpt       String   @default("")
  coverImageUrl String   @default("")
  published     Boolean  @default(false)
  slug          String   @default("") @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Skill {
  id       String @id @default(cuid())
  name     String @default("")
  category String @default("")
  level    Int    @default(50)
  icon     String @default("")
  order    Int    @default(0)
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String   @default("")
  email     String   @default("")
  subject   String   @default("")
  message   String   @default("")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Setting {
  key   String @id
  value String @default("")
}
