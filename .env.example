# Database — PostgreSQL (required for Vercel)
# Use a connection pooler URL for DATABASE_URL (e.g., Supabase, Neon, or Vercel Postgres)
# Use the direct connection URL for DIRECT_URL (needed for Prisma migrations)
DATABASE_URL=postgresql://user:password@host:5432/database?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/database

# Auth
NEXTAUTH_URL=https://your-domain.vercel.app
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
ADMIN_PASSWORD=change-this-password

# Email (Resend)
# Get your API key at https://resend.com/api-keys
# Use onboarding@resend.dev for testing (sends only to your account email)
# Replace with your verified domain email for production
RESEND_API_KEY=your-resend-api-key-here
EMAIL_FROM=onboarding@resend.dev

# Vercel Blob (for file uploads in production)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
